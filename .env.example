# ── Database ──────────────────────────────────────────────────────
# Railway auto-injects this when you add the Postgres plugin.
# For local dev: postgresql://USER:PASSWORD@localhost:5432/matrimony_db
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# ── Auth ──────────────────────────────────────────────────────────
# Random string, at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# ── CORS ──────────────────────────────────────────────────────────
# Your Vercel frontend URL. Multiple origins: url1,url2
FRONTEND_URL="https://your-app.vercel.app"

# ── Admin ─────────────────────────────────────────────────────────
# Secret required to register an ADMIN-role account
ADMIN_SECRET="change-me-admin-secret"
# Initial admin credentials (used by the seed script only)
ADMIN_EMAIL="admin@martmony.com"
ADMIN_PASSWORD="change-me-strong-password"

# ── Server ────────────────────────────────────────────────────────
# Railway sets PORT automatically; default 4000 locally
PORT=4000
